<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.example.mac-services-api</string>
    <key>ProgramArguments</key>
    <array>
        <string>/path/to/MacServicesAPI.app/Contents/MacOS/mac-services-api</string>
    </array>
    <key>WorkingDirectory</key>
    <string>/path/to/working-directory</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/path/to/logs/stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/path/to/logs/stderr.log</string>
</dict>
</plist>
